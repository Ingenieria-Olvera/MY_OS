# Where the scraped JSON digests get written. This must be a folder inside
# the Obsidian vault that's synced (e.g. via Syncthing) onto the phone running
# the MY OS app. The app reads <vault>/_inbox/slack_digest.json and
# <vault>/_inbox/email_digest.json from this folder.
VAULT_INBOX_DIR=/path/to/Cross_Study/_inbox

# Slack -- create an app at https://api.slack.com/apps, add a *User* OAuth
# token (not a bot token -- bot tokens can't use search.messages) with scopes:
# im:history, mpim:history, search:read, users:read. Install it to your
# workspace and copy the "User OAuth Token" (starts with xoxp-).
SLACK_USER_TOKEN=xoxp-...
SLACK_LOOKBACK_HOURS=24

# Gmail -- in Google Cloud Console, enable the Gmail API and create an OAuth
# client ID of type "Desktop app". Download its client secret JSON and point
# GMAIL_CLIENT_SECRET_FILE at it. GMAIL_TOKEN_FILE is where the refresh token
# gets cached after the first interactive login.
GMAIL_CLIENT_SECRET_FILE=/path/to/gmail_client_secret.json
GMAIL_TOKEN_FILE=/path/to/gmail_token.json
GMAIL_QUERY=is:unread is:important
GMAIL_MAX_RESULTS=25

# Root of the Obsidian vault itself (the parent of VAULT_INBOX_DIR). Used by
# todos_aggregator.py to scan your notes for "- [ ] ..." checkboxes, and by
# the local agent to read recent notes for context.
VAULT_ROOT_DIR=/path/to/Cross_Study

# Google Calendar -- enable the Calendar API in the same Google Cloud project
# as Gmail. Reuses GMAIL_CLIENT_SECRET_FILE by default; set
# GOOGLE_CALENDAR_CLIENT_SECRET_FILE only if you want a separate OAuth client.
# List your calendars (work/personal/school, etc) and a label for each, in
# the same order. "primary" is your main Google Calendar.
GOOGLE_CALENDAR_CLIENT_SECRET_FILE=
GOOGLE_CALENDAR_TOKEN_FILE=/path/to/google_calendar_token.json
GOOGLE_CALENDAR_IDS=primary,work@group.calendar.google.com,school@group.calendar.google.com
GOOGLE_CALENDAR_LABELS=personal,work,school
# Minimum free window (minutes) before it's worth suggesting exercise/study/wind-down.
CALENDAR_MIN_GAP_MINUTES=30

# Local AI agent -- run via `python -m agent.server` / `python -m agent.plan_digest`
# on the same machine as Ollama (laptop, mini PC, Jetson Nano). Point
# OLLAMA_MODEL at whatever small model you've pulled (e.g. `ollama pull
# llama3.2` or a Kimi/Qwen model). AGENT_HOST defaults to localhost-only;
# set it to 0.0.0.0 to let your phone reach it over the home Wi-Fi.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
AGENT_HOST=127.0.0.1
AGENT_PORT=8765
