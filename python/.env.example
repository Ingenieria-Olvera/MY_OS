# Where the scraped JSON digests get written. This must be a folder inside
# the Obsidian vault that's synced (e.g. via Syncthing) onto the phone running
# the MY OS app. The app reads <vault>/_inbox/slack_digest.json and
# <vault>/_inbox/email_digest.json from this folder.
VAULT_INBOX_DIR=/path/to/Cross_Study/_inbox

# Modes to control script behaviors:
# TEST_MODE=True prompts interactively for things like Google OAuth linking.
# PRODUCTION_MODE=True runs non-interactively for background deployments.
TEST_MODE=True
PRODUCTION_MODE=False


# Slack -- create an app at https://api.slack.com/apps, add a *User* OAuth
# token (not a bot token -- bot tokens can't use search.messages) with scopes:
# im:history, mpim:history, search:read, users:read. Install it to your
# workspace and copy the "User OAuth Token" (starts with xoxp-).
SLACK_USER_TOKEN=xoxp-...
SLACK_LOOKBACK_HOURS=24

# Google (Gmail + Calendar), one or more accounts -- in Google Cloud Console,
# enable the Gmail API and the Calendar API on the same project, then create
# one OAuth client ID of type "Desktop app" per account (or reuse one client
# across accounts -- see below). Download each client secret JSON. The first
# run against a given account opens a browser asking for both the
# gmail.readonly and calendar.readonly scopes together and caches the
# resulting token, so you only grant consent once per account -- after that
# both scrapers refresh silently from the cached token.
#
# GOOGLE_ACCOUNTS names your accounts; GOOGLE_CREDENTIALS_FILES and
# GOOGLE_TOKEN_FILES line up with it positionally. If you only have one
# credentials file (e.g. all your accounts are under the same Cloud project),
# list it once and it'll be reused for every account -- only the token files
# need to be distinct per account.
GOOGLE_ACCOUNTS=personal,uni,work
GOOGLE_CREDENTIALS_FILES=/path/to/credentials.json
GOOGLE_TOKEN_FILES=/path/to/personal_token.json,/path/to/uni_token.json,/path/to/work_token.json
GMAIL_QUERY=is:unread is:important
GMAIL_MAX_RESULTS=25
# Second search run alongside GMAIL_QUERY so mail Gmail itself wouldn't flag
# as "important" still gets surfaced -- bank/financial alerts, scholarship or
# financial-aid offers, recruiter/interview emails, etc. Results from both
# queries are merged and de-duplicated by message id; emails matched only by
# this query are marked with a 🔑 in email_digest.md. Set to "" to disable.
GMAIL_KEYWORD_QUERY=subject:(bank OR statement OR payment OR overdraft OR scholarship OR "financial aid" OR tuition OR refund OR invoice OR offer OR interview OR deadline OR application)

# Root of the Obsidian vault itself (the parent of VAULT_INBOX_DIR). Used by
# todos_aggregator.py to scan your notes for "- [ ] ..." checkboxes, and by
# the local agent to read recent notes for context.
VAULT_ROOT_DIR=/path/to/Cross_Study

# Google Calendar -- list your calendars (work/personal/school/uni, etc), a
# label for each, and which configured GOOGLE_ACCOUNTS entry owns it, all in
# the same order. "primary" is the main calendar for that account.
GOOGLE_CALENDAR_IDS=primary,primary,work@group.calendar.google.com
GOOGLE_CALENDAR_LABELS=personal,uni,work
GOOGLE_CALENDAR_ACCOUNT=personal,uni,work
# Minimum free window (minutes) before it's worth suggesting exercise/study/wind-down.
CALENDAR_MIN_GAP_MINUTES=30

# Local AI agent -- run via `python -m agent.server` / `python -m agent.plan_digest`
# on the same machine as Ollama (laptop, mini PC, Jetson Nano). Point
# OLLAMA_MODEL at whatever small model you've pulled (e.g. `ollama pull
# llama3.2` or a Kimi/Qwen model). AGENT_HOST defaults to localhost-only;
# set it to 0.0.0.0 to let your phone reach it over the home Wi-Fi.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
AGENT_HOST=127.0.0.1
AGENT_PORT=8765

# Set to true to also ask the local Ollama agent to infer todos from recent
# notes' prose (things you wrote down but never turned into a checkbox).
# Off by default so todos_aggregator.py never depends on Ollama being
# reachable -- it runs every few minutes via cron. Inferred todos are tagged
# source: "vault_inferred" in the digest.
TODOS_LLM_INFERENCE=false
TODOS_LLM_INFERENCE_LIMIT=5

# Set to a number of minutes (e.g. 15) to have `python -m agent.server` run
# the scrapers + todos_aggregator itself, on that interval, in a background
# thread -- a cron-free alternative for platforms like Windows. 0 (the
# default) disables this; keep using cron/Task Scheduler/manual runs instead.
AUTO_SCRAPE_INTERVAL_MINUTES=0
